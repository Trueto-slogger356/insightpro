{
  "family": "insightpro-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/insightpro-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [
        { "name": "AWS_REGION", "value": "us-east-1" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:<region>:<account-id>:parameter/insightpro/database-url" },
        { "name": "REDIS_URL", "valueFrom": "arn:aws:ssm:<region>:<account-id>:parameter/insightpro/redis-url" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:<region>:<account-id>:parameter/insightpro/jwt-secret" }
      ]
    }
  ]
}
